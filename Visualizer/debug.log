float3 Get1 (float2 uvi, float par)
{return lerp(GetBlur1(uvi), GetPixel(uvi), 0*saturate(par/2))*par;}

           void PS( float4 _vDiffuse : COLOR, float2 _uv : TEXCOORD0, float2 _rad_ang : TEXCOORD1, out float4 _return_value : COLOR0 )
 {    float3 ret = 0;

uva = (uv-0.5)*aspect.xy+0.5;
float moon = (.01 / length (uva-moonpos));

dz.x = lum(GetPixel(uv-hor)) - lum(GetPixel(uv+hor));
dz.y = lum(GetPixel(uv-ver)) - lum(GetPixel(uv+ver));

float3 shine = GetPixel(uv); 

radi = 1;
for (int n=1; n <= anz; n++)
{ 
