float3 shiftHSV(float3 c)
{
    float3 rgb = c;
    if (colshift_hue != 0.0 || colshift_saturation != 0.0 || colshift_brightness != 0.0)
    {
        float4 K = float4(0, -1.0 / 3.0, 2.0 / 3.0, -1);
