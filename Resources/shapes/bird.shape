shapecode_0_enabled=1
shapecode_0_sides=10
shapecode_0_additive=0
shapecode_0_thickOutline=0
shapecode_0_textured=0
shapecode_0_num_inst=1024
shapecode_0_x=0.500
shapecode_0_y=0.500
shapecode_0_rad=0.05539
shapecode_0_ang=0.00000
shapecode_0_tex_ang=0.31416
shapecode_0_tex_zoom=0.34420
shapecode_0_r=1.000
shapecode_0_g=1.000
shapecode_0_b=1.000
shapecode_0_a=1.000
shapecode_0_r2=0.000
shapecode_0_g2=0.000
shapecode_0_b2=0.000
shapecode_0_a2=0.000
shapecode_0_border_r=0.000
shapecode_0_border_g=0.000
shapecode_0_border_b=1.000
shapecode_0_border_a=0.000
shape_0_per_frame1=sample=instance/num_inst;
shape_0_per_frame2=
shape_0_per_frame3=///// bird with ellipses
shape_0_per_frame4=
shape_0_per_frame5=p0=20;   p1=p0*sample;    p2=p1%p0;    p3=3.2/p0;
shape_0_per_frame6=c=below(sample,.45);      c1=above(sample,.95);
shape_0_per_frame7=rad=rad*if(c1,.8*sin(-.2+p0*2.5*sample),sin(p0*3.14*sample));
shape_0_per_frame8=
shape_0_per_frame9=x=.5+p2-p1;               y=0;        t=p2*p3+1.57*c;          //// wings
shape_0_per_frame10=mx=x*sin(t)+y*cos(t);     my=y*sin(t)-x*cos(t);
shape_0_per_frame11=mx=if(c,-mx-.06*p2+.59,mx+.06*p2-1.18);
shape_0_per_frame12=
shape_0_per_frame13=mx=if(c1,0,mx);           my=if(c1,-26.5+27*sample,my);        //// body
shape_0_per_frame14=
shape_0_per_frame15=d=sqrt(mx*mx+sqr(my-.5));
shape_0_per_frame16=r=.8+.26*sin(1*d);   g=.5+.5*sin(7.5*d);      b=.2+.2*sin(13*d);
shape_0_per_frame17=
shape_0_per_frame18=
shape_0_per_frame19=t=2*time+q1;                                                  ///// movement
shape_0_per_frame20=mx=mx +.5*cos(t)*mx+.1*sin(mx*mx+my+t)*(my+mx);
shape_0_per_frame21=my=my +.15*sin(my+3*abs(mx)-t)*abs(mx)+.5*my*pow(mx,4)*sin(t);
shape_0_per_frame22=
shape_0_per_frame23=
shape_0_per_frame24=x=.5 + .13*mx*(1+.3*sin(.07*time)) /q6+.1*sin(.1*time);
shape_0_per_frame25=y=.5 + .13*my*(1+.3*sin(.07*time))+.3*sin(-.11*time);
shape_0_per_frame26=
shape_0_per_frame27=rad=rad*(1+.3*sin(.07*time));
