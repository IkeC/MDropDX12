shapecode_0_border_g=1.000
shapecode_0_border_b=1.000
shapecode_0_border_a=0.000
shape_0_per_frame1=i=instance;           sa=i/960;     
shape_0_per_frame2=i1=instance/6;        sa1=(i1%160)/160; 
shape_0_per_frame3=
shape_0_per_frame4=tt=q1;
shape_0_per_frame5=
shape_0_per_frame6=s1=2*8*sa1;   s2=(8*sa1)%8;   ss=s2/8;  
shape_0_per_frame7=c=int(s1)-2*s2;               s=s1-2*s2;   
shape_0_per_frame8=
shape_0_per_frame9=
shape_0_per_frame10=x0= (c==0)*(s-1) + (c==1)*(2-s) ;
shape_0_per_frame11=y0= (c==0)*(1-s) + (c==1)*(2-s);      y0*=.58;     
shape_0_per_frame12=
shape_0_per_frame13=x0 += .5*sin(1.3*tt+ss*2);
shape_0_per_frame14=y0 += .5*cos(1.3*tt+ss*2);
shape_0_per_frame15=
shape_0_per_frame16=
shape_0_per_frame17=t1= 3*sin(tt)+ 2*sin(.4*tt)*sin(2*ss+.8*tt);
shape_0_per_frame18=x1=x0*sin(t1)+y0*cos(t1); 
shape_0_per_frame19=y1=y0*sin(t1)-x0*cos(t1);
shape_0_per_frame20=
shape_0_per_frame21=d=sqrt(x1*x1+y1*y1);    
shape_0_per_frame22=
shape_0_per_frame23=
shape_0_per_frame24=z1= .4+.2*sin(.6*tt+2*ss);
shape_0_per_frame25=x1 *=  z1;    y1 *=  z1;
shape_0_per_frame26=
shape_0_per_frame27=
shape_0_per_frame28=t2 = 160*6.28*sa +.52*sa  + 3.14 - t1  ; 
shape_0_per_frame29=z2 = .06*z1;
shape_0_per_frame30=x2 = z2*sin(t2);    y2 = z2*cos(t2);     
shape_0_per_frame31=
shape_0_per_frame32=
shape_0_per_frame33=x=.5 + (x1+x2)/q6;
shape_0_per_frame34=y=.5 + y1+y2; 
shape_0_per_frame35=
shape_0_per_frame36=rad = 2.01*z2;     ang=3.14/4+t2;
shape_0_per_frame37=
shape_0_per_frame38=t3=.6+ .4*sin(3*d+t1); 
shape_0_per_frame39=t4=.6+ .4*cos(3*d+t1); 
shape_0_per_frame40=
shape_0_per_frame41=p =.1+.45*(i/2)%3;   
shape_0_per_frame42=
shape_0_per_frame43=r = p*t4;     r2=r;
shape_0_per_frame44=g = p*t3;     g2=g;
shape_0_per_frame45=b = g*g;      b2=b;
