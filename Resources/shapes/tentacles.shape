shapecode_0_enabled=1
shapecode_0_sides=4
shapecode_0_additive=0
shapecode_0_thickOutline=0
shapecode_0_textured=0
shapecode_0_num_inst=1024
shapecode_0_x=0.500
shapecode_0_y=0.500
shapecode_0_rad=2.70962
shapecode_0_ang=0.00000
shapecode_0_tex_ang=6.28319
shapecode_0_tex_zoom=1.19614
shapecode_0_r=0.030
shapecode_0_g=0.000
shapecode_0_b=0.000
shapecode_0_a=1.000
shapecode_0_r2=0.030
shapecode_0_g2=0.000
shapecode_0_b2=0.000
shapecode_0_a2=1.000
shapecode_0_border_r=1.000
shapecode_0_border_g=1.000
shapecode_0_border_b=1.000
shapecode_0_border_a=0.000
shape_0_per_frame1=i=instance;    t=q1;           sa=i/1024;
shape_0_per_frame2=
shape_0_per_frame3=c1=(i>=1);     c2=(i>=3)/2;    c3=(i>=7)/4;    c4=(i>=15)/8; 
shape_0_per_frame4=t1=6.28*i/2;   t2=t1/2;        t3=t2/2;        t4=t3/2;      
shape_0_per_frame5=
shape_0_per_frame6=
shape_0_per_frame7=x1= sin(t1+t);        y1=cos(t1+t);
shape_0_per_frame8=x2= sin(t2-2*t);      y2=cos(t2-2*t);
shape_0_per_frame9=x3= sin(t3+3*t);      y3=cos(t3+3*t);
shape_0_per_frame10=x4= sin(t4-4*t);      y4=cos(t4-4*t);
shape_0_per_frame11=
shape_0_per_frame12=
shape_0_per_frame13=x5 = c1*x1 + c2*x2 + c3*x3 + c4*x4 ;
shape_0_per_frame14=y5 = c1*y1 + c2*y2 + c3*y3 + c4*y4 ;
shape_0_per_frame15=
shape_0_per_frame16=ra = 2-c1-c2-c3-c4 ;
shape_0_per_frame17=
shape_0_per_frame18=
shape_0_per_frame19=z=(.2+.1*sin(.3*t))*(1+sa);
shape_0_per_frame20=x= .5 + z*x5/q6; 
shape_0_per_frame21=y= .5 + z*y5; 
shape_0_per_frame22=
shape_0_per_frame23=rad = 2*z*(ra-c4*sa); 
shape_0_per_frame24=
shape_0_per_frame25=
shape_0_per_frame26=p1=.6+.4*sin(3*sa-2*t);   
shape_0_per_frame27=p2=.6+.4*sin(500*sa-2*t);   
shape_0_per_frame28=
shape_0_per_frame29=r= if(c4,p1,p2);   r2=r*if(c4,1,.1);
shape_0_per_frame30=g= r*r;            g2=g*if(c4,1,.1);
shape_0_per_frame31=b= g*g;            b2=b*if(c4,1,.1);
shape_0_per_frame32=
shape_0_per_frame33=sides=40-20*c4*8;
