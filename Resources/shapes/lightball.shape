shape_0_per_frame1=sample=instance/num_inst;
shape_0_per_frame2=
shape_0_per_frame3=//// pyramid
shape_0_per_frame4=
shape_0_per_frame5=s=122*sample;
shape_0_per_frame6=t=-int(s);
shape_0_per_frame7=
shape_0_per_frame8=x=bnot(t)*(-.5);              y=bnot(t)*(-.89+1.8*s);       z=0;
shape_0_per_frame9=x=x+bnot(t+1)*(-2+1.5*s);     y=y+bnot(t+1)*(-1.8+.9*s);    z=z;
shape_0_per_frame10=x=x+bnot(t+2)*(-3.5+1.5*s);   y=y+bnot(t+2)*(2.7-.9*s);     z=z;
shape_0_per_frame11=x=x+bnot(t+3)*(1.5-.5*s);     y=y+bnot(t+3)*(-2.7+.9*s);    z=z+bnot(t+3)*(4.-s);
shape_0_per_frame12=x=x+bnot(t+4)*(2.-.5*s);      y=y+bnot(t+4)*(3.6-.9*s);     z=z+bnot(t+4)*(5-s);
shape_0_per_frame13=x=x+bnot(t+5)*(6-s);          y=y;                          z=z+bnot(t+5)*(-5+s);
shape_0_per_frame14=
shape_0_per_frame15=
shape_0_per_frame16=my_x=x;
shape_0_per_frame17=my_y=y;
shape_0_per_frame18=my_z=z;
shape_0_per_frame19=
shape_0_per_frame20=//// rotations
shape_0_per_frame21=
shape_0_per_frame22=d = q9; 
shape_0_per_frame23=zoom =q9;
shape_0_per_frame24=
shape_0_per_frame25=w1 = q11;
shape_0_per_frame26=w2 = q12;
shape_0_per_frame27=w3 = q13;
shape_0_per_frame28=
shape_0_per_frame29=x1 = cos(w1)*my_x + sin(w1)*my_y;
shape_0_per_frame30=y1 = -sin(w1)*my_x + cos(w1)*my_y;
shape_0_per_frame31=z1 = my_z;
shape_0_per_frame32=
shape_0_per_frame33=x2 = cos(w2)*x1 + sin(w2)*z1;
shape_0_per_frame34=z2 = -sin(w2)*x1 + cos(w2)*z1;
shape_0_per_frame35=y2 = y1;
shape_0_per_frame36=
shape_0_per_frame37=y3 = cos(w3)*y2 + sin(w3)*z2;
shape_0_per_frame38=z3 = -sin(w3)*y2 + cos(w3)*z2;
shape_0_per_frame39=x3 = x2;
shape_0_per_frame40=
shape_0_per_frame41=l = sqrt(x3*x3 + y3*y3);
shape_0_per_frame42=w = atan2(x3,y3);
shape_0_per_frame43=d = sqrt(x3*x3 + y3*y3 + (z3+d)*(z3+d));
shape_0_per_frame44=p = tan(asin(1) + atan2(d+z3,l));
shape_0_per_frame45=
shape_0_per_frame46=my_x = zoom*sin(w)*p;
shape_0_per_frame47=my_y = zoom*cos(w)*p;
shape_0_per_frame48=
shape_0_per_frame49=x = 0.5 + my_x/q6;
shape_0_per_frame50=y = 0.5 + my_y/q5;
shape_0_per_frame51=
shape_0_per_frame52=
shape_0_per_frame53=r=1-.5*sample;
shape_0_per_frame54=g=r;
shape_0_per_frame55=r2=r;
shape_0_per_frame56=g2=g;
shape_0_per_frame57=
shape_0_per_frame58=rad=.7*rad*zoom/d;
