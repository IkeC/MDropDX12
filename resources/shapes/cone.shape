shapecode_0_enabled=1
shapecode_0_sides=20
shapecode_0_additive=0
shapecode_0_thickOutline=0
shapecode_0_textured=0
shapecode_0_num_inst=500
shapecode_0_x=0.500
shapecode_0_y=0.500
shapecode_0_rad=0.03646
shapecode_0_ang=0.00000
shapecode_0_tex_ang=0.00000
shapecode_0_tex_zoom=1.00183
shapecode_0_r=0.100
shapecode_0_g=0.600
shapecode_0_b=0.900
shapecode_0_a=0.060
shapecode_0_r2=0.100
shapecode_0_g2=0.600
shapecode_0_b2=0.900
shapecode_0_a2=0.040
shapecode_0_border_r=1.000
shapecode_0_border_g=1.000
shapecode_0_border_b=1.000
shapecode_0_border_a=0.120
shape_0_per_frame1=sample=instance/num_inst;
shape_0_per_frame2=rad=.15*sample;
shape_0_per_frame3=ang=sample*time*15;
shape_0_per_frame4=b=sample;
shape_0_per_frame5=g=b;
shape_0_per_frame6=r=b;
shape_0_per_frame7=
shape_0_per_frame8=///// Cone
shape_0_per_frame9=r1=1;
shape_0_per_frame10=r2=.3;
shape_0_per_frame11=q10=sample;
shape_0_per_frame12=q11=80*sample;
shape_0_per_frame13=
shape_0_per_frame14=my_x = ((r1-q10)/r1)*r2*cos(q11);
shape_0_per_frame15=my_y = ((r1-q10)/r1)*r2*sin(q11);
shape_0_per_frame16=my_z = -q10;
shape_0_per_frame17=
shape_0_per_frame18=
shape_0_per_frame19=/////// rotations... by flexi
shape_0_per_frame20=d = 10;
shape_0_per_frame21=zoom = 10;
shape_0_per_frame22=
shape_0_per_frame23=w3 = .7+.1*sin(q2);
shape_0_per_frame24=w2 = .02*sin(q3);
shape_0_per_frame25=w1 = 3*q1;
shape_0_per_frame26=
shape_0_per_frame27=x1 = cos(w1)*my_x + sin(w1)*my_y;
shape_0_per_frame28=y1 = -sin(w1)*my_x + cos(w1)*my_y;
shape_0_per_frame29=z1 = my_z;
shape_0_per_frame30=
shape_0_per_frame31=x2 = cos(w2)*x1 + sin(w2)*z1;
shape_0_per_frame32=z2 = -sin(w2)*x1 + cos(w2)*z1;
shape_0_per_frame33=y2 = y1;
shape_0_per_frame34=
shape_0_per_frame35=y3 = cos(w3)*y2 + sin(w3)*z2;
shape_0_per_frame36=z3 = -sin(w3)*y2 + cos(w3)*z2;
shape_0_per_frame37=x3 = x2;
shape_0_per_frame38=
shape_0_per_frame39=// perspective calculation
shape_0_per_frame40=
shape_0_per_frame41=l = sqrt(x3*x3 + y3*y3);
shape_0_per_frame42=w = atan2(x3,y3);
shape_0_per_frame43=p = tan(asin(1) + atan2(d+z3,l));
shape_0_per_frame44=d = sqrt(x3*x3 + y3*y3 + (z3+d)*(z3+d));
shape_0_per_frame45=
shape_0_per_frame46=my_x = zoom*sin(w)*p;
shape_0_per_frame47=my_y = zoom*cos(w)*p;
shape_0_per_frame48=
shape_0_per_frame49=x = 0.5 + my_x/q6;
shape_0_per_frame50=y = 0.1 + my_y/q5;
