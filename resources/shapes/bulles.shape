shape_0_per_frame57=// perspective calculation
shape_0_per_frame58=
shape_0_per_frame59=l = sqrt(x3*x3 + y3*y3);
shape_0_per_frame60=w = atan2(x3,y3);
shape_0_per_frame61=p = tan(asin(1) + atan2(d+z3,l));
shape_0_per_frame62=d = sqrt(x3*x3 + y3*y3 + (z3+d)*(z3+d));
shape_0_per_frame63=
shape_0_per_frame64=my_x = zoom*sin(w)*p;
shape_0_per_frame65=my_y = zoom*cos(w)*p;
